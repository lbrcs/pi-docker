#!/usr/bin/env bash
set -e

# ── Resolve pi-docker home (where this script lives) ─────────────────────
PI_DOCKER_HOME="$(cd "$(dirname "$0")" && pwd -P)"

# ── Parse --rebuild / --update flags ─────────────────────────────────────
REBUILD=0
UPDATE=0
PASSTHROUGH_ARGS=()
for arg in "$@"; do
    if [ "$arg" = "--rebuild" ]; then
        REBUILD=1
    elif [ "$arg" = "--update" ]; then
        UPDATE=1
    else
        PASSTHROUGH_ARGS+=("$arg")
    fi
done
set -- "${PASSTHROUGH_ARGS[@]}"

# ── Find the repo root ───────────────────────────────────────────────────
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "Error: not inside a git repository." >&2
    exit 1
}

BRANCH=$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)

echo "────────────────────────────────────────────"
echo "│ pi-docker"
echo "│ repo:   $(basename "$REPO_ROOT")"
echo "│ branch: $BRANCH"
echo "│ path:   $REPO_ROOT"
echo "────────────────────────────────────────────"

# ── Rebuild / update image if requested ──────────────────────────────────
if [ "$UPDATE" -eq 1 ]; then
    echo "│ Updating Pi to latest version (no-cache build)..."
    docker compose -f "$PI_DOCKER_HOME/docker-compose.yml" build --no-cache pi
    rm -f "$PI_DOCKER_HOME/.version-cache"
    echo "│ Update complete."
    echo "────────────────────────────────────────────"
elif [ "$REBUILD" -eq 1 ]; then
    echo "│ Rebuilding Docker images..."
    docker compose -f "$PI_DOCKER_HOME/docker-compose.yml" build
    echo "│ Rebuild complete."
    echo "────────────────────────────────────────────"
fi

# ── Load GitHub token ────────────────────────────────────────────────────
# Priority: PI_GH_TOKEN env var > ~/.pi-docker/.gh-auth-token file
if [ -z "$PI_GH_TOKEN" ] && [ -f "$PI_DOCKER_HOME/.gh-auth-token" ]; then
    PI_GH_TOKEN="$(cat "$PI_DOCKER_HOME/.gh-auth-token")"
fi

if [ -z "$PI_GH_TOKEN" ]; then
    echo ""
    echo "⚠   No GitHub token found."
    echo "   Set PI_GH_TOKEN or create $PI_DOCKER_HOME/.gh-auth-token"
    echo "   See: https://github.com/settings/tokens?type=beta"
    echo ""
    read -p "Continue without GitHub access? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# ── Check for auth ───────────────────────────────────────────────────────
PI_AUTH_FILE="$HOME/.pi/agent/auth.json"

# Returns 0 if any auth method is configured: any subscription key in auth.json
# (anthropic, copilot, etc.) OR a direct ANTHROPIC_API_KEY env var.
_has_pi_auth() {
    [ -n "${ANTHROPIC_API_KEY:-}" ] && return 0
    [ -f "$PI_AUTH_FILE" ] || return 1
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "
import json, sys
try:
    data = json.load(open('$PI_AUTH_FILE'))
    sys.exit(0 if data else 1)
except:
    sys.exit(1)
" 2>/dev/null
    else
        # Fallback: non-empty file with at least one key character is good enough
        grep -q '"[^"]\+":' "$PI_AUTH_FILE" 2>/dev/null
    fi
}

if ! _has_pi_auth; then
    echo ""
    echo "⚠   No auth configured."
    echo "   Run 'pi-docker-auth' to log in (Anthropic or GitHub Copilot),"
    echo "   or set ANTHROPIC_API_KEY."
    echo ""
    read -p "Continue without auth? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
else
    # Warn if the OAuth session token is expired (python3 may not be available on all hosts)
    if [ -f "$PI_AUTH_FILE" ] && command -v python3 >/dev/null 2>&1; then
        TOKEN_EXPIRES=$(python3 -c "
import json, sys
try:
    data = json.load(open('$PI_AUTH_FILE'))
    cred = data.get('anthropic', {})
    expires = cred.get('expires', 0)
    print(int(expires))
except Exception:
    print(0)
" 2>/dev/null)
        NOW_MS=$(python3 -c "import time; print(int(time.time() * 1000))")
        if [ -n "$TOKEN_EXPIRES" ] && [ "$TOKEN_EXPIRES" -gt 0 ] && [ "$TOKEN_EXPIRES" -lt "$NOW_MS" ]; then
            echo ""
            echo "⚠   Anthropic session token is expired."
            echo "   Pi will attempt to refresh it automatically on startup."
            echo "   If you see auth errors, run 'pi-docker-auth' to re-authenticate."
            echo ""
        fi
    fi
fi

# ── Check for Pi updates (cached, bounded to ~5s on cache miss) ───────────
_check_pi_update() {
    # Skip if image doesn't exist yet (first run before any build)
    docker image inspect pi-agent >/dev/null 2>&1 || return

    local cache_file="$PI_DOCKER_HOME/.version-cache"
    local now; now=$(date +%s)
    local cached_installed="" cached_latest="" cached_ts=0

    if [ -f "$cache_file" ]; then
        IFS='|' read -r cached_installed cached_latest cached_ts < "$cache_file" 2>/dev/null || true
        if [ $((now - cached_ts)) -lt 3600 ] && [ -n "$cached_installed" ] && [ -n "$cached_latest" ]; then
            if [ "$cached_installed" != "$cached_latest" ]; then
                echo ""
                echo "⚠   Pi update available: $cached_installed → $cached_latest"
                echo "   Run 'pi-docker --update' to upgrade."
                echo ""
            fi
            return
        fi
    fi

    # Read installed version from image without starting a container:
    # docker create+cp is metadata-only (no entrypoint, no process spawned)
    local installed cid
    cid=$(docker create pi-agent 2>/dev/null) || return
    installed=$(docker cp "$cid:/etc/pi-agent-version" - 2>/dev/null | tar -xOf - 2>/dev/null | tr -d '[:space:]')
    docker rm -f "$cid" >/dev/null 2>&1
    [ -z "$installed" ] && return

    # Fetch latest from npm registry via curl — no npm required on the host.
    # --max-time 5 keeps the check bounded when the network is slow or offline.
    local latest
    latest=$(curl -sf --max-time 5 \
        "https://registry.npmjs.org/@mariozechner%2Fpi-coding-agent" 2>/dev/null \
        | python3 -c "import json,sys; print(json.load(sys.stdin)['dist-tags']['latest'])" 2>/dev/null \
        | tr -d '[:space:]')
    [ -z "$latest" ] && return

    echo "${installed}|${latest}|${now}" > "$cache_file"

    if [ "$installed" != "$latest" ]; then
        echo ""
        echo "⚠   Pi update available: $installed → $latest"
        echo "   Run 'pi-docker --update' to upgrade."
        echo ""
    fi
}
if [ "$UPDATE" -eq 0 ] && [ "$REBUILD" -eq 0 ]; then
    _check_pi_update
fi

# ── Ensure pi-managed dirs are gitignored ────────────────────────────────
GITIGNORE="$REPO_ROOT/.gitignore"
for entry in '.worktrees/' '.pi/'; do
    if ! grep -qxF "$entry" "$GITIGNORE" 2>/dev/null; then
        echo "$entry" >> "$GITIGNORE"
        echo "[setup] Added $entry to .gitignore"
    fi
done

# ── Launch ────────────────────────────────────────────────────────────────
# ── Build compose file list (add override if Ollama is enabled) ───────────
COMPOSE_ARGS=(-f "$PI_DOCKER_HOME/docker-compose.yml")
if [ -f "$PI_DOCKER_HOME/docker-compose.override.yml" ]; then
    COMPOSE_ARGS+=(-f "$PI_DOCKER_HOME/docker-compose.override.yml")
    echo "│ ollama: enabled (override detected)"
fi

PI_REPO="$REPO_ROOT" \
PI_DOCKER_HOME="$PI_DOCKER_HOME" \
PI_GH_TOKEN="${PI_GH_TOKEN:-}" \
    docker compose "${COMPOSE_ARGS[@]}" run --rm --service-ports pi "$@"
