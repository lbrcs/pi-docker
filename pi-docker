#!/usr/bin/env bash
set -e

# ── Resolve pi-docker home (where this script lives) ─────────────────────
PI_DOCKER_HOME="$(cd "$(dirname "$0")" && pwd -P)"

# ── Parse --rebuild flag ──────────────────────────────────────────────────
REBUILD=0
PASSTHROUGH_ARGS=()
for arg in "$@"; do
    if [ "$arg" = "--rebuild" ]; then
        REBUILD=1
    else
        PASSTHROUGH_ARGS+=("$arg")
    fi
done
set -- "${PASSTHROUGH_ARGS[@]}"

# ── Find the repo root ───────────────────────────────────────────────────
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "Error: not inside a git repository." >&2
    exit 1
}

BRANCH=$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)

echo "────────────────────────────────────────────"
echo "│ pi-docker"
echo "│ repo:   $(basename "$REPO_ROOT")"
echo "│ branch: $BRANCH"
echo "│ path:   $REPO_ROOT"
echo "────────────────────────────────────────────"

# ── Rebuild image if requested ────────────────────────────────────────────
if [ "$REBUILD" -eq 1 ]; then
    echo "│ Rebuilding Docker images..."
    docker compose -f "$PI_DOCKER_HOME/docker-compose.yml" build
    echo "│ Rebuild complete."
    echo "────────────────────────────────────────────"
fi

# ── Load GitHub token ────────────────────────────────────────────────────
# Priority: PI_GH_TOKEN env var > ~/.pi-docker/.gh-auth-token file
if [ -z "$PI_GH_TOKEN" ] && [ -f "$PI_DOCKER_HOME/.gh-auth-token" ]; then
    PI_GH_TOKEN="$(cat "$PI_DOCKER_HOME/.gh-auth-token")"
fi

if [ -z "$PI_GH_TOKEN" ]; then
    echo ""
    echo "⚠   No GitHub token found."
    echo "   Set PI_GH_TOKEN or create $PI_DOCKER_HOME/.gh-auth-token"
    echo "   See: https://github.com/settings/tokens?type=beta"
    echo ""
    read -p "Continue without GitHub access? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# ── Check for auth ───────────────────────────────────────────────────────
PI_AUTH_FILE="$HOME/.pi/agent/auth.json"

# Returns 0 if any auth method is configured: any subscription key in auth.json
# (anthropic, copilot, etc.) OR a direct ANTHROPIC_API_KEY env var.
_has_pi_auth() {
    [ -n "${ANTHROPIC_API_KEY:-}" ] && return 0
    [ -f "$PI_AUTH_FILE" ] || return 1
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "
import json, sys
try:
    data = json.load(open('$PI_AUTH_FILE'))
    sys.exit(0 if data else 1)
except:
    sys.exit(1)
" 2>/dev/null
    else
        # Fallback: non-empty file with at least one key character is good enough
        grep -q '"[^"]\+":' "$PI_AUTH_FILE" 2>/dev/null
    fi
}

if ! _has_pi_auth; then
    echo ""
    echo "⚠   No auth configured."
    echo "   Run 'pi-docker-auth' to log in (Anthropic or GitHub Copilot),"
    echo "   or set ANTHROPIC_API_KEY."
    echo ""
    read -p "Continue without auth? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
else
    # Warn if the OAuth session token is expired (python3 may not be available on all hosts)
    if [ -f "$PI_AUTH_FILE" ] && command -v python3 >/dev/null 2>&1; then
        TOKEN_EXPIRES=$(python3 -c "
import json, sys
try:
    data = json.load(open('$PI_AUTH_FILE'))
    cred = data.get('anthropic', {})
    expires = cred.get('expires', 0)
    print(int(expires))
except Exception:
    print(0)
" 2>/dev/null)
        NOW_MS=$(python3 -c "import time; print(int(time.time() * 1000))")
        if [ -n "$TOKEN_EXPIRES" ] && [ "$TOKEN_EXPIRES" -gt 0 ] && [ "$TOKEN_EXPIRES" -lt "$NOW_MS" ]; then
            echo ""
            echo "⚠   Anthropic session token is expired."
            echo "   Pi will attempt to refresh it automatically on startup."
            echo "   If you see auth errors, run 'pi-docker-auth' to re-authenticate."
            echo ""
        fi
    fi
fi

# ── Ensure pi-managed dirs are gitignored ────────────────────────────────
GITIGNORE="$REPO_ROOT/.gitignore"
for entry in '.worktrees/' '.pi/'; do
    if ! grep -qxF "$entry" "$GITIGNORE" 2>/dev/null; then
        echo "$entry" >> "$GITIGNORE"
        echo "[setup] Added $entry to .gitignore"
    fi
done

# ── Scope compose project name to this repo ──────────────────────────────
# Each repo gets its own compose project so sessions in different repos are
# fully independent — tearing down one never affects another.
COMPOSE_PROJECT="pi-$(basename "$REPO_ROOT" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-\+$//')"
echo "│ project: $COMPOSE_PROJECT"
echo "│ compose: docker compose -f \"$PI_DOCKER_HOME/docker-compose.yml\" -p \"$COMPOSE_PROJECT\" ..."
echo "────────────────────────────────────────────"

# ── Tear down any stale session for this repo ─────────────────────────────
# Ensures the proxy always starts fresh with the current squid.conf.
# Scoped to COMPOSE_PROJECT so only this repo's containers are affected.
docker compose -f "$PI_DOCKER_HOME/docker-compose.yml" -p "$COMPOSE_PROJECT" down --remove-orphans 2>/dev/null || true

# ── Launch ────────────────────────────────────────────────────────────────
# ── Build compose file list (add override if Ollama is enabled) ───────────
COMPOSE_ARGS=(-f "$PI_DOCKER_HOME/docker-compose.yml" -p "$COMPOSE_PROJECT")
if [ -f "$PI_DOCKER_HOME/docker-compose.override.yml" ]; then
    COMPOSE_ARGS+=(-f "$PI_DOCKER_HOME/docker-compose.override.yml")
    echo "│ ollama: enabled (override detected)"
fi

PI_REPO="$REPO_ROOT" \
PI_DOCKER_HOME="$PI_DOCKER_HOME" \
PI_GH_TOKEN="${PI_GH_TOKEN:-}" \
    docker compose "${COMPOSE_ARGS[@]}" run --rm --service-ports pi "$@"
