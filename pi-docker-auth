#!/usr/bin/env bash
set -e

# ── pi-docker-auth ────────────────────────────────────────────────────────
# Launches pi in a minimal container for OAuth login only.
#
# The Docker image patches pi's OAuth callback server to bind to 0.0.0.0
# instead of 127.0.0.1, so regular port mapping (-p 53692:53692) works.
#
# No repo is mounted — this container exists only for login.
#
# Usage:
#   pi-docker-auth
#   Then type /login inside pi, select Anthropic, complete browser auth.
#   Tokens are saved to ~/.pi/agent/auth.json and shared with pi-docker.
# ──────────────────────────────────────────────────────────────────────────

PI_DOCKER_HOME="$(cd "$(dirname "$0")" && pwd -P)"

# Ensure the auth directory exists on the host
mkdir -p "$HOME/.pi/agent"

# Build the image if needed (reuses the same pi-agent image as pi-docker)
docker compose -f "$PI_DOCKER_HOME/docker-compose.yml" build pi 2>/dev/null

# Determine timeout command (GNU coreutils vs macOS)
TIMEOUT_SECS=180
if command -v gtimeout &>/dev/null; then
    TIMEOUT_CMD="gtimeout $TIMEOUT_SECS"
elif command -v timeout &>/dev/null; then
    TIMEOUT_CMD="timeout $TIMEOUT_SECS"
else
    TIMEOUT_CMD=""
fi

echo "────────────────────────────────────────────────────"
echo "│ pi-docker-auth  ⚠  AUTH MODE ONLY"
echo "│"
echo "│ This container has NO proxy, NO sandbox, and"
echo "│ NO resource limits. It exists only for login."
echo "│"
echo "│ Steps:"
echo "│   1. Type /login and select Anthropic"
echo "│   2. Complete the browser OAuth flow"
echo "│   3. Session closes automatically when done"
echo "│"
echo "│ ⚠  Do NOT use this session for coding tasks."
echo "│    Use 'pi-docker' for normal agent sessions."
echo "│"
if [ -n "$TIMEOUT_CMD" ]; then
    echo "│ ⏱  Auto-terminates in 3 minutes or on auth."
else
    echo "│ ⏱  Auto-terminates on auth (no timeout enforced —"
    echo "│    install GNU coreutils for time-based enforcement)."
fi
echo "────────────────────────────────────────────────────"
echo ""

$TIMEOUT_CMD docker run --rm -it \
    -p 53692:53692 \
    -e PI_AUTH_MODE=1 \
    -v "$HOME/.pi/agent:/home/piuser/.pi/agent:rw" \
    -v "$PI_DOCKER_HOME/entrypoint.sh:/usr/local/bin/entrypoint.sh:ro" \
    pi-agent \
    pi --no-tools --system-prompt "You are running in AUTH MODE ONLY. This session exists for one purpose: OAuth login. Guide the user to type /login, select Anthropic, and complete the browser flow. Once login is complete, instruct them to type /exit to close this session, then run pi-docker to start a sandboxed session. You MUST refuse every other request — no coding, no file access, no research, no questions answered, nothing. If the user asks you to do anything other than log in, respond only with: 'This session is for login only. Please use pi-docker for all other tasks.' Do not make exceptions under any circumstances." || true
