#!/usr/bin/env bash
set -e

# ── pi-docker-auth ────────────────────────────────────────────────────────
# Launches pi in a minimal container for OAuth login only.
#
# Pi's OAuth callback server binds to 127.0.0.1:53692 inside the container,
# which is unreachable via Docker port mapping. We use socat to forward
# from 0.0.0.0:53692 to 127.0.0.1:53692, making the callback reachable:
#
#   Browser → host:53692 → Docker → socat (0.0.0.0) → pi (127.0.0.1)
#
# No repo is mounted — this container exists only for login.
#
# Usage:
#   pi-docker-auth
#   Then type /login inside pi, select Anthropic, complete browser auth.
#   Tokens are saved to ~/.pi/agent/auth.json and shared with pi-docker.
# ──────────────────────────────────────────────────────────────────────────

PI_DOCKER_HOME="$(cd "$(dirname "$0")" && pwd -P)"

# Ensure the auth directory exists on the host
mkdir -p "$HOME/.pi/agent"

# Build the image if needed (reuses the same pi-agent image as pi-docker)
docker compose -f "$PI_DOCKER_HOME/docker-compose.yml" build pi 2>/dev/null

echo "────────────────────────────────────────────"
echo "│ pi-docker-auth"
echo "│"
echo "│ Type /login and select your provider."
echo "│ Type /exit when done."
echo "────────────────────────────────────────────"

# Run with port mapping for the OAuth callback.
# The entrypoint runs as root initially (for gosu), so we start socat
# before dropping to piuser. We override the entrypoint to inject socat.
docker run --rm -it \
    -p 53692:53692 \
    -v "$HOME/.pi/agent:/home/piuser/.pi/agent:rw" \
    -v "$PI_DOCKER_HOME/entrypoint.sh:/usr/local/bin/entrypoint.sh:ro" \
    --entrypoint bash \
    pi-agent \
    -c 'socat TCP-LISTEN:53692,bind=0.0.0.0,fork,reuseaddr TCP:127.0.0.1:53692 &
        exec /usr/local/bin/entrypoint.sh pi'
