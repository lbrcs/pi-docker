#!/usr/bin/env bash
set -e

# ── Resolve pi-docker home (where this script lives) ─────────────────────
PI_DOCKER_HOME="$(cd "$(dirname "$0")" && pwd -P)"

# ── Generated file paths ─────────────────────────────────────────────────
OVERRIDE_FILE="$PI_DOCKER_HOME/docker-compose.override.yml"
SQUID_LOCAL="$PI_DOCKER_HOME/squid-local.conf"
# models.json is written to ~/.pi/agent/ because that directory is already
# bind-mounted into the container by docker-compose.yml. Mounting a file
# inside an already-mounted directory causes Docker to fail with an OCI
# "mountpoint outside of rootfs" error, so we write directly to the host
# path that the container already sees.
MODELS_FILE="$HOME/.pi/agent/models.json"

# ── Platform detection ────────────────────────────────────────────────────
detect_ollama_host() {
    case "$(uname -s)" in
        Darwin) echo "host.docker.internal" ;;
        *)      echo "172.17.0.1" ;;
    esac
}

# ── Ollama API helpers ────────────────────────────────────────────────────
ollama_api_url() {
    echo "http://localhost:11434"
}

ollama_is_running() {
    curl -s --max-time 3 "$(ollama_api_url)/api/tags" > /dev/null 2>&1
}

ollama_installed_models() {
    curl -s --max-time 5 "$(ollama_api_url)/api/tags" \
        | grep -o '"name":"[^"]*"' \
        | sed 's/"name":"//;s/"//'
}

# ── models.json helpers ──────────────────────────────────────────────────
read_models_json() {
    if [ -f "$MODELS_FILE" ]; then
        cat "$MODELS_FILE"
    else
        echo '{}'
    fi
}

models_in_json() {
    if [ ! -f "$MODELS_FILE" ]; then
        return
    fi
    grep -o '"id": *"[^"]*"' "$MODELS_FILE" | sed 's/"id": *"//;s/"//'
}

write_models_json() {
    local host="$1"
    shift
    local models=("$@")

    local model_entries=""
    for m in "${models[@]}"; do
        if [ -n "$model_entries" ]; then
            model_entries="$model_entries,"
        fi
        model_entries="$model_entries
        { \"id\": \"$m\" }"
    done

    cat > "$MODELS_FILE" <<EOF
{
  "providers": {
    "ollama": {
      "baseUrl": "http://${host}:11434/v1",
      "api": "openai-completions",
      "apiKey": "ollama",
      "models": [${model_entries}
      ]
    }
  }
}
EOF
}

# ── Generate squid-local.conf ────────────────────────────────────────────
generate_squid_local() {
    local host="$1"

    # Copy base squid.conf, remove old commented ollama block, insert active rules before "deny all"
    sed '/^# ── LOCAL MODEL FALLBACK/,/^$/d' "$PI_DOCKER_HOME/squid.conf" \
        | sed "/^http_access deny all/i\\
\\
# ── Ollama (local model) ─────────────────────────────────────────────\\
acl ollama_host dst ${host}\\
acl ollama_port port 11434\\
http_access allow ollama_host ollama_port" \
        > "$SQUID_LOCAL"
}

# ── Generate docker-compose.override.yml ─────────────────────────────────
generate_override() {
    local host="$1"

    # Note: models.json is NOT mounted here. It is written directly to
    # $HOME/.pi/agent/models.json, which is already bind-mounted into the
    # container by the base docker-compose.yml. Adding a nested file mount
    # inside that directory causes an OCI "mountpoint outside of rootfs" error.
    cat > "$OVERRIDE_FILE" <<EOF
# Auto-generated by pi-docker-models — do not edit manually
services:
  proxy:
    volumes:
      - ./squid-local.conf:/etc/squid/squid.conf:ro

  pi:
    environment:
      OLLAMA_HOST: "http://${host}:11434"
EOF
}

# ── Commands ─────────────────────────────────────────────────────────────

cmd_enable() {
    local host="${OLLAMA_HOST_OVERRIDE:-$(detect_ollama_host)}"

    echo "── Checking Ollama on localhost:11434 ──"
    if ! ollama_is_running; then
        echo "⚠  Ollama is not running on localhost:11434."
        echo "   Start it with: ollama serve"
        echo ""
        read -p "Continue anyway? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    else
        echo "✓  Ollama is running"
    fi

    # Generate override files
    generate_squid_local "$host"
    echo "✓  Generated squid-local.conf (allowing $host:11434)"

    generate_override "$host"
    echo "✓  Generated docker-compose.override.yml"

    # Auto-sync models if Ollama is running
    if ollama_is_running; then
        echo ""
        echo "── Syncing installed Ollama models ──"
        cmd_sync_quiet "$host"
    else
        # Write empty models.json
        write_models_json "$host"
        echo "✓  Generated models.json (empty — run 'pi-docker-models ollama sync' after starting Ollama)"
    fi

    echo ""
    echo "✅ Ollama integration enabled (host: $host)"
    echo "   Models will appear in pi's model picker alongside Anthropic."
    echo "   Restart pi-docker to apply changes."
}

cmd_disable() {
    local removed=0

    for f in "$OVERRIDE_FILE" "$SQUID_LOCAL" "$MODELS_FILE"; do
        if [ -f "$f" ]; then
            rm "$f"
            echo "✓  Removed $f"
            removed=1
        fi
    done

    if [ "$removed" -eq 0 ]; then
        echo "Nothing to disable — Ollama integration is not enabled."
    else
        echo ""
        echo "✅ Ollama integration disabled. Restart pi-docker to apply."
    fi
}

cmd_list() {
    echo "── Installed Ollama models ──"
    if ! ollama_is_running; then
        echo "⚠  Ollama is not running on localhost:11434"
        return 1
    fi

    local installed
    installed=$(ollama_installed_models)

    if [ -z "$installed" ]; then
        echo "   (none)"
        return
    fi

    local configured
    configured=$(models_in_json)

    while IFS= read -r model; do
        if echo "$configured" | grep -qxF "$model"; then
            echo "   ✓ $model  (in models.json)"
        else
            echo "     $model"
        fi
    done <<< "$installed"
}

cmd_sync_quiet() {
    local host="${1:-$(detect_ollama_host)}"

    if ! ollama_is_running; then
        echo "⚠  Ollama is not running — cannot sync."
        return 1
    fi

    local installed
    installed=$(ollama_installed_models)

    if [ -z "$installed" ]; then
        echo "   No models installed in Ollama."
        write_models_json "$host"
        return
    fi

    local models=()
    while IFS= read -r model; do
        models+=("$model")
        echo "   + $model"
    done <<< "$installed"

    write_models_json "$host" "${models[@]}"
    echo "✓  models.json updated (${#models[@]} model(s))"
}

cmd_sync() {
    echo "── Syncing Ollama models to models.json ──"

    local host
    if [ -f "$OVERRIDE_FILE" ]; then
        host=$(grep -oP 'OLLAMA_HOST: "http://\K[^:]+' "$OVERRIDE_FILE" 2>/dev/null || detect_ollama_host)
    else
        host=$(detect_ollama_host)
    fi

    cmd_sync_quiet "$host"
}

cmd_add() {
    local model="$1"
    if [ -z "$model" ]; then
        echo "Usage: pi-docker-models ollama add <model-name>"
        echo "Example: pi-docker-models ollama add qwen2.5-coder:32b"
        exit 1
    fi

    local host
    if [ -f "$OVERRIDE_FILE" ]; then
        host=$(grep -oP 'OLLAMA_HOST: "http://\K[^:]+' "$OVERRIDE_FILE" 2>/dev/null || detect_ollama_host)
    else
        host=$(detect_ollama_host)
    fi

    # Check if already in models.json
    if models_in_json | grep -qxF "$model"; then
        echo "Model '$model' is already in models.json."
        return
    fi

    # Collect existing models + new one
    local models=()
    while IFS= read -r m; do
        [ -n "$m" ] && models+=("$m")
    done <<< "$(models_in_json)"
    models+=("$model")

    write_models_json "$host" "${models[@]}"
    echo "✓  Added '$model' to models.json (${#models[@]} model(s) total)"
}

cmd_remove() {
    local model="$1"
    if [ -z "$model" ]; then
        echo "Usage: pi-docker-models ollama remove <model-name>"
        exit 1
    fi

    if ! models_in_json | grep -qxF "$model"; then
        echo "Model '$model' is not in models.json."
        return
    fi

    local host
    if [ -f "$OVERRIDE_FILE" ]; then
        host=$(grep -oP 'OLLAMA_HOST: "http://\K[^:]+' "$OVERRIDE_FILE" 2>/dev/null || detect_ollama_host)
    else
        host=$(detect_ollama_host)
    fi

    local models=()
    while IFS= read -r m; do
        [ -n "$m" ] && [ "$m" != "$model" ] && models+=("$m")
    done <<< "$(models_in_json)"

    write_models_json "$host" "${models[@]}"
    echo "✓  Removed '$model' from models.json (${#models[@]} model(s) remaining)"
}

cmd_status() {
    echo "── pi-docker-models status ──"
    echo ""

    if [ -f "$OVERRIDE_FILE" ]; then
        echo "Ollama integration: ENABLED"
        local host
        host=$(grep -oP 'OLLAMA_HOST: "http://\K[^:]+' "$OVERRIDE_FILE" 2>/dev/null || echo "unknown")
        echo "Ollama host:        $host"
    else
        echo "Ollama integration: DISABLED"
        echo ""
        echo "Run 'pi-docker-models ollama enable' to set up local models."
        return
    fi

    echo ""
    if [ -f "$MODELS_FILE" ]; then
        echo "Configured models:"
        while IFS= read -r m; do
            [ -n "$m" ] && echo "  • $m"
        done <<< "$(models_in_json)"
    else
        echo "Configured models:  (none)"
    fi

    echo ""
    if ollama_is_running; then
        echo "Ollama server:      running ✓"
    else
        echo "Ollama server:      not running ⚠"
    fi
}

# ── Usage ────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
Usage: pi-docker-models <command>

Commands:
  ollama enable [--host HOST]   Enable Ollama integration (auto-syncs models)
  ollama disable                Disable Ollama integration (removes override files)
  ollama list                   Show installed Ollama models
  ollama sync                   Sync all installed Ollama models to models.json
  ollama add <model>            Add a model to models.json
  ollama remove <model>         Remove a model from models.json
  status                        Show current configuration

Environment:
  OLLAMA_HOST_OVERRIDE          Override auto-detected Docker host for Ollama

Examples:
  pi-docker-models ollama enable
  pi-docker-models ollama enable --host 192.168.1.100
  pi-docker-models ollama add qwen2.5-coder:32b
  pi-docker-models ollama sync
  pi-docker-models status
EOF
}

# ── Argument parsing ─────────────────────────────────────────────────────
case "${1:-}" in
    ollama)
        case "${2:-}" in
            enable)
                # Parse --host flag
                if [ "${3:-}" = "--host" ] && [ -n "${4:-}" ]; then
                    OLLAMA_HOST_OVERRIDE="$4"
                fi
                cmd_enable
                ;;
            disable)  cmd_disable ;;
            list)     cmd_list ;;
            sync)     cmd_sync ;;
            add)      cmd_add "${3:-}" ;;
            remove)   cmd_remove "${3:-}" ;;
            *)        usage; exit 1 ;;
        esac
        ;;
    status) cmd_status ;;
    -h|--help|help) usage ;;
    *) usage; exit 1 ;;
esac
